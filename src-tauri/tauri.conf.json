{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Free-SVN",
  "version": "0.1.0",
  "identifier": "com.free-svn.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "cnpm run dev",
    "beforeBuildCommand": "cnpm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Free-SVN",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../public/fonts/*": "fonts/",
      "svn-resources/macos/bin/*": "svn/macos/",
      "svn-resources/macos/lib/*.dylib": "svn/macos/lib/",
      "svn-resources/windows/svn.exe": "svn/windows/",
      "svn-resources/windows/*.dll": "svn/windows/",
      "svn-resources/linux/bin/*": "svn/linux/",
      "svn-resources/linux/lib/*": "svn/linux/lib/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
